# ─── Credentials ───
# Get from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot token from @BotFather (leave empty for user-account mode)
BOT_TOKEN=

# Session string for user mode (alternative to interactive auth)
# Generate with: python telegram_forwarder.py --generate-session
# Leave empty if using BOT_TOKEN or interactive auth
SESSION_STRING=

# ─── Options ───
REMOVE_FORWARD_SIGNATURE=false
DISABLE_CONSOLE_LOG=false
SYNC_MISSED_MESSAGES=false

# ─── Forwarding Rules (numbered pairs) ───
# Simple: one source → one target
SOURCE_1=-1001111111111
TARGET_1=-1002222222222

# With topics: source topic 5 → target topic 10
# SOURCE_2=-1001111111111/5
# TARGET_2=-1003333333333/10

# One-to-many: one source → multiple targets (comma-separated)
# SOURCE_3=-1004444444444
# TARGET_3=-1005555555555,-1006666666666


# ─── Legacy (compact format, still supported) ───
# FORWARDING_RULES=-1001111111111:-1002222222222,-1003333333333:-1004444444444
# SOURCE_ID=-1001111111111
# TARGET_ID=-1002222222222
